<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access for recording meetings -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Network access for Ollama + Notion API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- MLX uses JIT / Metal compute — requires unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow loading third-party native libraries (PortAudio, MLX dylibs) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
